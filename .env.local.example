# ============================================================
# 問い合わせ支援 AI アシスタント - 環境変数設定
# このファイルをコピーして .env.local を作成してください
# cp .env.local.example .env.local
# ============================================================

# ============================================================
# ── LLM プロバイダ選択 ──────────────────────────────────────
# LLM_PROVIDER=gemini  → Google Gemini API (無料枠あり・クラウド)
# LLM_PROVIDER=ollama  → Ollama ローカル LLM (完全無料・プライベート)
# ============================================================
LLM_PROVIDER=gemini

# ---- Google Gemini (LLM_PROVIDER=gemini のとき必須) ----
# 取得先: https://aistudio.google.com/apikey (無料)
# 無料枠: gemini-2.0-flash は 1日 1,500 リクエスト / 1分 15 リクエスト
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# ---- Ollama ローカル LLM (LLM_PROVIDER=ollama のとき使用) ----
# インストール: https://ollama.ai
# モデル取得例: ollama pull qwen2.5:7b
# 推奨モデル: qwen2.5:7b (日本語対応良好), llama3.2:3b (軽量), gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ============================================================
# ── Embedding プロバイダ選択 ────────────────────────────────
# EMBEDDING_PROVIDER=ollama → ローカル Ollama (完全無料、DB 移行不要)
# EMBEDDING_PROVIDER=gemini → Gemini API (無料枠あり、1024d なら DB 移行不要)
#
# ⚠️ 次元数の注意:
#   - ollama + mxbai-embed-large → 1024 次元 (デフォルト、DB 変更不要)
#   - ollama + nomic-embed-text  → 768 次元  (scripts/migrate-768.sql が必要)
#   - gemini + gemini-embedding-001 → 1024 次元 (デフォルト、DB 変更不要)
# ============================================================
EMBEDDING_PROVIDER=ollama

# ---- Ollama Embedding (EMBEDDING_PROVIDER=ollama のとき使用) ----
# モデル取得例: ollama pull mxbai-embed-large
# 推奨: mxbai-embed-large (1024d, DB 変更不要)
#       nomic-embed-text   (768d, 軽量, migrate-768.sql 必要)
OLLAMA_EMBED_MODEL=mxbai-embed-large

# ---- Gemini Embedding (EMBEDDING_PROVIDER=gemini のとき使用) ----
# GEMINI_API_KEY は上記と共通。デフォルトは DB 初期スキーマに合わせて 1024 次元。
# 768 次元で使う場合のみ migrate-768.sql の実行 + EMBEDDING_DIM=768 の設定が必要。
GEMINI_EMBED_MODEL=gemini-embedding-001

# ---- Embedding 次元数 (DB スキーマと一致させること) ----
# mxbai-embed-large → 1024 (デフォルト・省略可)
# gemini-embedding-001 → 1024 (デフォルト・省略可)
# nomic-embed-text / Gemini 768 次元運用 → 768 (migrate-768.sql 必要)
EMBEDDING_DIM=1024

# ============================================================
# ── データベース (Supabase PostgreSQL + pgvector) ────────────
# https://supabase.com → プロジェクト → Settings → Database → Connection string
# Transaction pooler (ポート 6543) を使用 ※ サーバーレス/Vercel 環境向け
# ============================================================
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ============================================================
# ── NextAuth.js ─────────────────────────────────────────────
# ============================================================
# ランダムな文字列を生成: openssl rand -base64 32
# Auth.js v5 の標準名。NEXTAUTH_SECRET も後方互換で読み取ります。
AUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here

# Google OAuth
# https://console.cloud.google.com/ でOAuth 2.0クライアントを作成
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ============================================================
# ── MCP API Key (オプション) ─────────────────────────────────
# MCP HTTP エンドポイントへのアクセス制御
# 本番環境では必ず設定してください（未設定時は本番でアクセス拒否）
# ============================================================
MCP_API_KEY=your-mcp-api-key
